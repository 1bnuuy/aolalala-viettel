{
  "name": "hert-hospital-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:chatbot": "node --import tsx apps/chatbot-api/src/server.ts",
    "dev:mcp": "node --import tsx packages/hert-hospital-mcp/src/server.ts",
    "import:data": "node --import tsx scripts/import-data.ts",
    "import:faq": "node --import tsx scripts/import-faq-sql.ts",
    "seed:demo": "node --import tsx scripts/seed-demo-knowledge.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "fastify": "^5.6.0",
    "pg": "^8.16.3",
    "xlsx": "^0.18.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0"
  }
}
